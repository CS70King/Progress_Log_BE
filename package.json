{
  "name": "progress-log-backend",
  "version": "1.0.0",
  "description": "Progress Log MVP backend service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:development": "cross-env ENV_FILE=.env.development tsx watch src/server.ts",
    "dev:staging": "cross-env ENV_FILE=.env.staging tsx watch src/server.ts",
    "dev:nodemon": "nodemon",
    "dev:development:nodemon": "cross-env ENV_FILE=.env.development nodemon",
    "dev:staging:nodemon": "cross-env ENV_FILE=.env.staging nodemon",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:development": "cross-env ENV_FILE=.env.development node dist/server.js",
    "start:staging": "cross-env ENV_FILE=.env.staging node dist/server.js",
    "start:production": "cross-env ENV_FILE=.env.production node dist/server.js",
    "db:generate": "prisma generate",
    "db:generate:development": "cross-env ENV_FILE=.env.development prisma generate",
    "db:generate:staging": "cross-env ENV_FILE=.env.staging prisma generate",
    "db:generate:production": "cross-env ENV_FILE=.env.production prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:development": "cross-env ENV_FILE=.env.development prisma migrate dev",
    "db:migrate:staging": "cross-env ENV_FILE=.env.staging prisma migrate deploy",
    "db:migrate:production": "cross-env ENV_FILE=.env.production prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:development": "cross-env ENV_FILE=.env.development tsx prisma/seed.ts",
    "test": "cross-env ENV_FILE=.env.development NODE_ENV=test STORAGE_DRIVER=mock tsx --test tests/**/*.test.ts"
  },
  "keywords": [
    "progress-log",
    "backend",
    "express",
    "prisma",
    "supabase"
  ],
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.49.8",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.10",
    "prisma": "^7.8.0",
    "supertest": "^7.1.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
