generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  WORKER   @map("worker")
  REVIEWER @map("reviewer")

  @@map("user_role")
}

enum ProjectType {
  GENERIC      @map("generic")
  CONSTRUCTION @map("construction")
  SERVICE      @map("service")

  @@map("project_type")
}

enum ProjectMemberRole {
  OWNER    @map("owner")
  REVIEWER @map("reviewer")

  @@map("project_member_role")
}

enum ProjectState {
  ACTIVE    @map("active")
  COMPLETED @map("completed")
  ABANDONED @map("abandoned")

  @@map("project_state")
}

enum MilestoneStatus {
  DRAFT          @map("draft")
  SUBMITTED      @map("submitted")
  APPROVED       @map("approved")
  NEEDS_REVISION @map("needs_revision")
  DISAPPROVED    @map("disapproved")

  @@map("milestone_status")
}

enum ReviewDecision {
  APPROVED       @map("approved")
  NEEDS_REVISION @map("needs_revision")

  @@map("review_decision")
}

enum EvidenceType {
  PHOTO    @map("photo")
  VIDEO    @map("video")
  DOCUMENT @map("document")
  RECEIPT  @map("receipt")
  OTHER    @map("other")

  @@map("evidence_type")
}

enum ShareResourceType {
  PROJECT  @map("project")
  SNAPSHOT @map("snapshot")

  @@map("share_resource_type")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  role         UserRole
  name         String
  phone        String   @unique
  country      String
  company      String?
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  ownedProjects      Project[]         @relation("ProjectOwner")
  projectMemberships ProjectMember[]
  createdMilestones  Milestone[]       @relation("MilestoneCreator")
  milestoneReviews   MilestoneReview[] @relation("MilestoneReviewer")
  uploadedEvidence   EvidenceItem[]    @relation("EvidenceUploader")
  createdSnapshots   Snapshot[]        @relation("SnapshotCreator")
  createdShareLinks  ShareLink[]       @relation("ShareLinkCreator")

  @@map("users")
}

model Project {
  id          String      @id @default(uuid()) @db.Uuid
  ownerId     String      @map("owner_id") @db.Uuid
  title       String
  description String?
  projectType ProjectType @map("project_type")
  state       ProjectState @default(ACTIVE)
  dedupeKey   String?     @unique @map("dedupe_key")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner      User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  members    ProjectMember[]
  milestones Milestone[]
  evidence   EvidenceItem[]
  snapshots  Snapshot[]

  @@map("projects")
}

model ProjectMember {
  id        String            @id @default(uuid()) @db.Uuid
  projectId String            @map("project_id") @db.Uuid
  userId    String            @map("user_id") @db.Uuid
  role      ProjectMemberRole
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Milestone {
  id           String          @id @default(uuid()) @db.Uuid
  projectId    String          @map("project_id") @db.Uuid
  createdBy    String          @map("created_by") @db.Uuid
  title        String
  description  String
  activityDate DateTime        @map("activity_date") @db.Date
  status       MilestoneStatus @default(DRAFT)
  submittedAt  DateTime?       @map("submitted_at") @db.Timestamptz(6)
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator       User             @relation("MilestoneCreator", fields: [createdBy], references: [id])
  review        MilestoneReview?
  evidenceItems EvidenceItem[]

  @@map("milestones")
}

model MilestoneReview {
  id          String         @id @default(uuid()) @db.Uuid
  milestoneId String         @unique @map("milestone_id") @db.Uuid
  reviewerId  String         @map("reviewer_id") @db.Uuid
  decision    ReviewDecision
  note        String?
  reviewedAt  DateTime       @default(now()) @map("reviewed_at") @db.Timestamptz(6)

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  reviewer  User      @relation("MilestoneReviewer", fields: [reviewerId], references: [id])

  @@map("milestone_reviews")
}

model EvidenceItem {
  id               String       @id @default(uuid()) @db.Uuid
  projectId        String       @map("project_id") @db.Uuid
  milestoneId      String       @map("milestone_id") @db.Uuid
  uploadedBy       String       @map("uploaded_by") @db.Uuid
  evidenceType     EvidenceType @map("evidence_type")
  filePath         String       @map("file_path")
  originalFilename String       @map("original_filename")
  contentType      String       @map("content_type")
  sizeBytes        BigInt       @map("size_bytes")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  uploader  User      @relation("EvidenceUploader", fields: [uploadedBy], references: [id])

  @@map("evidence_items")
}

model Snapshot {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @map("project_id") @db.Uuid
  createdBy        String    @map("created_by") @db.Uuid
  title            String
  fromDate         DateTime? @map("from_date") @db.Date
  toDate           DateTime? @map("to_date") @db.Date
  milestoneIds     Json      @map("milestone_ids")
  immutablePayload Json      @map("immutable_payload")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation("SnapshotCreator", fields: [createdBy], references: [id])

  @@map("snapshots")
}

model ShareLink {
  id           String            @id @default(uuid()) @db.Uuid
  token        String            @unique
  resourceType ShareResourceType @map("resource_type")
  resourceId   String            @map("resource_id") @db.Uuid
  createdBy    String            @map("created_by") @db.Uuid
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  revokedAt    DateTime?         @map("revoked_at") @db.Timestamptz(6)
  expiresAt    DateTime?         @map("expires_at") @db.Timestamptz(6)

  creator User @relation("ShareLinkCreator", fields: [createdBy], references: [id])

  @@map("share_links")
}
